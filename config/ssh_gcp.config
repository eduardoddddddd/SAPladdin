# SSH config para VMs GCP de Eduardo Abdul Malik
# Archivo: C:\Users\Edu\SAPladdin\config\ssh_gcp.config
# Uso: ssh -F C:\Users\Edu\SAPladdin\config\ssh_gcp.config astromalik-server
#      o configurar en ~/.ssh/config: Include C:\Users\Edu\SAPladdin\config\ssh_gcp.config

# GCP - AstroMalik Server principal (europe-southwest1-a, e2-standard-2)
# IP: 34.175.40.49 | Usuario: Edu | Clave: google_compute_engine
Host astromalik-server astromalik 34.175.40.49
    HostName 34.175.40.49
    User Edu
    IdentityFile C:\Users\Edu\.ssh\google_compute_engine
    IdentitiesOnly yes
    StrictHostKeyChecking no
    UserKnownHostsFile NUL
    ServerAliveInterval 60
    ServerAliveCountMax 3

# GCP - SAP ABAP Docker (europe-west1-b) - TERMINATED normalmente
# IP: 34.14.2.5 | Usuario: Edu | Clave: google_compute_engine
Host sapdocker abap-docker-host 34.14.2.5
    HostName 34.14.2.5
    User Edu
    IdentityFile C:\Users\Edu\.ssh\google_compute_engine
    IdentitiesOnly yes
    StrictHostKeyChecking no
    UserKnownHostsFile NUL
